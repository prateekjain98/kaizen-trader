# ─── Core ───────────────────────────────────────────────────────────────────
# Set to true to simulate trades without placing real orders
PAPER_TRADING=true

# ─── Exchanges ──────────────────────────────────────────────────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── AI ─────────────────────────────────────────────────────────────────────
# Used by the self-healing log analyzer
ANTHROPIC_API_KEY=

# ─── News & Social ──────────────────────────────────────────────────────────
CRYPTOPANIC_TOKEN=           # https://cryptopanic.com/developers/api/
SERPER_API_KEY=              # https://serper.dev
TWITTER_BEARER_TOKEN=        # https://developer.x.com
LUNARCRUSH_API_KEY=          # https://lunarcrush.com/developers

# ─── On-chain ───────────────────────────────────────────────────────────────
WHALE_ALERT_API_KEY=         # https://whale-alert.io
ETHERSCAN_API_KEY=           # https://etherscan.io/apis (wallet tracking)

# ─── Risk ───────────────────────────────────────────────────────────────────
MAX_POSITION_USD=100         # Max size per trade
MAX_DAILY_LOSS_USD=300       # Circuit breaker threshold
MAX_OPEN_POSITIONS=5         # Concurrent open trades

# ─── Self-healing ───────────────────────────────────────────────────────────
# How often Claude Code runs the log analysis loop (in minutes)
LOG_ANALYSIS_INTERVAL_MINS=60
# Minimum number of closed trades before analysis fires
MIN_TRADES_FOR_ANALYSIS=10
