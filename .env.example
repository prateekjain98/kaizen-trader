# ─── Mode ────────────────────────────────────────────────────────────────────
# Keep true until you've validated the system with paper trades
PAPER_TRADING=true

# ─── AI (required for self-healing log analysis) ──────────────────────────────
ANTHROPIC_API_KEY=

# ─── Coinbase (required for price feed and order execution) ──────────────────
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ─── Binance (optional — enables shorts, funding rates, liquidation stream) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Social signals ───────────────────────────────────────────────────────────
# LunarCrush aggregates Twitter, Reddit, YouTube, TikTok — one key covers all social signals
LUNARCRUSH_API_KEY=

# ─── News signals ─────────────────────────────────────────────────────────────
CRYPTOPANIC_TOKEN=

# ─── On-chain signals ─────────────────────────────────────────────────────────
WHALE_ALERT_API_KEY=

# ─── Risk limits ─────────────────────────────────────────────────────────────
MAX_POSITION_USD=100
MAX_DAILY_LOSS_USD=300
MAX_OPEN_POSITIONS=5

# ─── Self-healing schedule ────────────────────────────────────────────────────
# How often Claude runs the deep log analysis (minutes)
LOG_ANALYSIS_INTERVAL_MINS=60
# Minimum closed trades before analysis fires
MIN_TRADES_FOR_ANALYSIS=10

# ─── Database ─────────────────────────────────────────────────────────────────
CONVEX_URL=
DB_PATH=trader.db

# ─── GitHub automation ────────────────────────────────────────────────────────
GITHUB_REPO=

# ─── Deployment ───────────────────────────────────────────────────────────────
PORT=8080
